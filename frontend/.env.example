# Development environment variables
# Copy this to .env and configure for your local development

# For local development, use relative paths (handled by Vite proxy)
VITE_API_URL=/api
VITE_WS_URL=/ws
VITE_EVENTS_URL=/events

# For production, you can either:
# 1. Use relative paths and configure Vercel rewrites
# 2. Point to your backend server directly
# Example: VITE_API_URL=https://your-backend-api.com/api
